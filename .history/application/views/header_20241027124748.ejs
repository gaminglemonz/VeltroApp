<header class="p-6 fixed left-0 top-0 w-full flex self-center justify-start items-center bg-white shadow-lg">
    <img src="images/veltro.png" width="100">
    <h1 class="text-3xl font-bold">Veltro</h1>

    <div class="relative left-[200px]">
        <% if (user) { %>
            <form action="/logout" method="POST">
                <a href="/login" class=" p-4 text-2xl font-bold border-gray-500 border-2 rounded-xl">Login</a>
            </form>
            <a href="/profile" class="font-bold text-2xl">Profile</a>
        <% } else { %>
            <a href="/login" class=" p-4 text-2xl font-bold border-gray-500 border-2 rounded-xl">Login</a>
            <a href="/signup" class="p-4 text-2xl font-bold text-white bg-gradient-to-r from-sky-500 to-indigo-500 rounded-xl">Sign Up</a>
        <% } %>
    </div>
</header>