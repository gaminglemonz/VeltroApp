<header style="font-family: Afacad Flux" class="p-6 fixed left-0 top-0 w-full flex self-center justify-start items-center bg-white shadow-lg">
    <a href="/home" class="inline">
        <img src="images/veltro.png" class="mx-5" width="80">
        <h1 class="text-3xl font-bold">Veltro</h1>
    </a>
    <div class="relative left-[70%]">
        <% if (user) { %>
            <form class='inline mx-5' action="/logout" method="POST">
                <button type="submit" class=" p-3 text-xl font-bold border-gray-500 border-2 rounded-xl">Logout</button>
            </form>
            <a href="/profile" class="font-bold text-xl"><%= user.username || user.name %></a>
        <% } else { %>
            <a href="/login" class=" p-4 text-xl font-bold border-gray-500 border-2 rounded-xl mx-3">Login</a>
            <a href="/signup" class="p-4 text-xl font-bold text-white bg-gradient-to-r from-sky-500 to-indigo-500 rounded-xl">Sign Up</a>
        <% } %>
    </div>
</header>